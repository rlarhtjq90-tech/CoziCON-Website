generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// =============================================
// Enums
// =============================================

enum UserType {
  GENERAL_CONTRACTOR   // 종합건설사 (공고 등록 · 관리)
  SPECIALTY_CONTRACTOR // 전문건설사 (입찰 제출)
}

enum UserStatus {
  PENDING   // 서류 미제출 / 승인 대기
  ACTIVE    // 정상 사용
  REJECTED  // 반려
  SUSPENDED // 정지
}

enum VerificationResult {
  VALID
  INVALID
  ERROR
}

// =============================================
// NextAuth 기본 모델
// =============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  userType      UserType?
  status        UserStatus @default(PENDING)
  companyId     String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  accounts       Account[]
  sessions       Session[]
  company        Company?              @relation(fields: [companyId], references: [id])
  termsConsents  TermsConsent[]
  verifications  CompanyVerification[]
  bidNotices     BidNotice[]
  bidSubmissions BidSubmission[]
  contractSigns  ContractSign[]
  notifications  Notification[]
  bookmarks      NoticeBookmark[]
  qnaQuestions   BidQnA[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================
// 회사 정보
// =============================================

model Company {
  id                   String   @id @default(cuid())
  bizNo                String   @unique
  name                 String
  ceoName              String?
  address              String?
  phone                String?
  fax                  String?
  website              String?
  type                 UserType
  businessVerified     Boolean  @default(false)
  bizDocUrl            String?
  logoUrl              String?
  constructionCapacity String?
  mainRegions          String[]
  constructionRecords  Json?
  equipmentAndStaff    Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @default(now()) @updatedAt

  users          User[]
  licenses       License[]
  verifications  CompanyVerification[]
  bidNotices     BidNotice[]
  bidSubmissions BidSubmission[]
  contractsAsGC  Contract[]            @relation("ContractGC")
  contractsAsSC  Contract[]            @relation("ContractSC")
  portfolios      Portfolio[]
  reviewsGiven    CompanyReview[] @relation("ReviewsGiven")
  reviewsReceived CompanyReview[] @relation("ReviewsReceived")
}

// =============================================
// 건설업 면허
// =============================================

model License {
  id          String    @id @default(cuid())
  companyId   String
  licenseType String
  grade       String?
  licenseNo   String?
  issuedAt    DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// =============================================
// 사업자등록 진위확인 이력
// =============================================

model CompanyVerification {
  id           String             @id @default(cuid())
  companyId    String
  bizNo        String
  result       VerificationResult
  responseData Json?
  verifiedAt   DateTime           @default(now())
  verifiedBy   String?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [verifiedBy], references: [id])
}

// =============================================
// 입찰공고 시스템
// =============================================

enum BidStatus {
  DRAFT     // 임시저장
  OPEN      // 모집중
  CLOSED    // 마감 (개찰 대기)
  OPENED    // 개찰됨 (입찰가 공개)
  CANCELLED // 취소
}

enum ContractStatus {
  PENDING    // 낙찰 후 서명 대기
  GC_SIGNED  // 발주사 서명 완료
  ACTIVE     // 계약 성립 (양측 서명)
  COMPLETED  // 공사 완료
  TERMINATED // 중도 해지
}

model BidNotice {
  id                String    @id @default(cuid())
  title             String
  workTypes         String[]
  regions           String[]
  estimatedPrice    BigInt?
  bidMethod         String?
  requiredLicenses  String[]
  qualificationNote String?   @db.Text
  deadline          DateTime
  openingAt         DateTime?
  constructionStart DateTime?
  constructionEnd   DateTime?
  description       String?   @db.Text
  status            BidStatus @default(DRAFT)
  isHidden          Boolean   @default(false)
  companyId         String
  authorId          String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  company     Company             @relation(fields: [companyId], references: [id])
  author      User                @relation(fields: [authorId], references: [id])
  attachments BidAttachment[]
  submissions BidSubmission[]
  categories  BidNoticeCategory[]
  contracts   Contract[]
  bookmarks   NoticeBookmark[]
  qnaList     BidQnA[]
}

model BidAttachment {
  id        String   @id @default(cuid())
  noticeId  String
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  notice BidNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
}

// =============================================
// 입찰 제출 시스템 (Phase 3)
// =============================================

enum BidSubmissionStatus {
  SUBMITTED // 제출됨
  REVIEWED  // 검토중
  ACCEPTED  // 낙찰
  REJECTED  // 탈락
}

model BidSubmission {
  id            String              @id @default(cuid())
  noticeId      String
  companyId     String
  bidderId      String
  proposedPrice String?  // AES-256-GCM encrypted; see src/lib/crypto.ts
  description   String?             @db.Text
  status        BidSubmissionStatus @default(SUBMITTED)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @default(now()) @updatedAt

  notice   BidNotice  @relation(fields: [noticeId], references: [id])
  company  Company    @relation(fields: [companyId], references: [id])
  bidder   User       @relation(fields: [bidderId], references: [id])
  contract Contract?

  @@unique([noticeId, companyId])
}

// =============================================
// 공종 분류 마스터 (Day 8)
// =============================================

model WorkCategory {
  id        String          @id @default(cuid())
  name      String
  code      String          @unique
  parentId  String?
  order     Int             @default(0)

  parent    WorkCategory?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  WorkCategory[]  @relation("CategoryHierarchy")
  notices   BidNoticeCategory[]
}

model BidNoticeCategory {
  noticeId    String
  categoryId  String

  notice   BidNotice    @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  category WorkCategory @relation(fields: [categoryId], references: [id])

  @@id([noticeId, categoryId])
}

// =============================================
// 계약 시스템 (Phase 4)
// =============================================

model Contract {
  id             String         @id @default(cuid())
  noticeId       String
  submissionId   String         @unique
  gcCompanyId    String
  scCompanyId    String
  contractAmount BigInt?
  status         ContractStatus @default(PENDING)
  gcSignedAt     DateTime?
  scSignedAt     DateTime?
  startDate      DateTime?
  endDate        DateTime?
  terms          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt

  notice     BidNotice     @relation(fields: [noticeId], references: [id])
  submission BidSubmission @relation(fields: [submissionId], references: [id])
  gcCompany  Company       @relation("ContractGC", fields: [gcCompanyId], references: [id])
  scCompany  Company       @relation("ContractSC", fields: [scCompanyId], references: [id])
  signs      ContractSign[]
  review     CompanyReview?
}

model ContractSign {
  id          String   @id @default(cuid())
  contractId  String
  userId      String
  role        String   // "GC" | "SC"
  signedAt    DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([contractId, role])
}

// =============================================
// 공고별 Q&A
// =============================================

model BidQnA {
  id        String    @id @default(cuid())
  noticeId  String
  askerId   String
  question  String    @db.Text
  answer    String?   @db.Text
  answeredAt DateTime?
  isAnon    Boolean   @default(false)
  createdAt DateTime  @default(now())

  notice BidNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  asker  User      @relation(fields: [askerId], references: [id])
}

// =============================================
// 관심공고 (즐겨찾기)
// =============================================

model NoticeBookmark {
  userId   String
  noticeId String

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notice BidNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@id([userId, noticeId])
}

// =============================================
// 인앱 알림
// =============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // BID_AWARDED | BID_REJECTED | NEW_BID | CONTRACT_SIGN_REQUEST | CONTRACT_ACTIVE | ADMIN_APPROVED | ADMIN_REJECTED
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// =============================================
// 공지사항
// =============================================

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

// =============================================
// 약관 동의 기록
// =============================================

model TermsConsent {
  id           String   @id @default(cuid())
  userId       String
  termsVersion String
  agreedAt     DateTime @default(now())
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// =============================================
// SC 포트폴리오 (시공 실적)
// =============================================

model Portfolio {
  id           String    @id @default(cuid())
  companyId    String
  title        String
  client       String
  startDate    DateTime
  endDate      DateTime
  amount       BigInt?
  workCategory String
  description  String?   @db.Text
  docUrl       String?
  createdAt    DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// =============================================
// GC → SC 리뷰
// =============================================

model CompanyReview {
  id                String   @id @default(cuid())
  contractId        String   @unique
  reviewerCompanyId String
  targetCompanyId   String
  rating            Int
  comment           String?  @db.Text
  createdAt         DateTime @default(now())

  contract        Contract @relation(fields: [contractId], references: [id])
  reviewerCompany Company  @relation("ReviewsGiven",    fields: [reviewerCompanyId], references: [id])
  targetCompany   Company  @relation("ReviewsReceived", fields: [targetCompanyId],   references: [id])
}
