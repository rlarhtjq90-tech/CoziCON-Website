# =============================================
# DB — Neon PostgreSQL
# =============================================
# 개발용: neon.tech 프로젝트 > dev branch
DATABASE_URL=postgresql://user:password@ep-xxx-dev.neon.tech/cozicon?sslmode=require
# 운영용: neon.tech 프로젝트 > main branch
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.neon.tech/cozicon?sslmode=require

# =============================================
# NextAuth
# =============================================
NEXTAUTH_SECRET=your_random_32_char_secret
# 로컬: http://localhost:3000 / 운영: https://cozi-con-website-2ano.vercel.app
NEXTAUTH_URL=http://localhost:3000

# =============================================
# 이메일 — Gmail SMTP (현재 사용 중)
# =============================================
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# =============================================
# 이메일 — Resend (Gmail 대체 / 도메인 발송 권장)
# =============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# 발송 도메인 (SPF/DKIM 설정 후): noreply@yourdomain.com
RESEND_FROM_EMAIL=noreply@yourdomain.com

# =============================================
# 에러 모니터링 — Sentry
# =============================================
# sentry.io 에서 프로젝트 생성 후 DSN 복사
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=cozicon
# sentry.io > Settings > Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxx

# =============================================
# 파일 스토리지 — Supabase Storage (권장) 또는 AWS S3
# =============================================
# [Supabase]
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxx

# [AWS S3 대안]
# AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# S3_BUCKET_NAME=cozicon-uploads

# =============================================
# 외부 API — 국세청 사업자등록 진위확인
# =============================================
# data.go.kr > 국세청_사업자등록정보 진위확인 및 상태조회 서비스
# 승인 후 일반 인증키(Encoding) 입력
NTS_API_KEY=your_nts_service_key

# =============================================
# 외부 API — 국토교통부 건설업등록정보 (기존)
# =============================================
CONSTRUCTION_API_KEY=your_service_key_here

# =============================================
# 알림톡 — Aligo 또는 NHN Toast
# =============================================
# [Aligo 카카오 알림톡]
# ALIGO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ALIGO_USER_ID=your_aligo_id
# ALIGO_SENDER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================
# PG사 — 토스페이먼츠 (결제, Post-MVP)
# =============================================
# TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxx
# TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxx
